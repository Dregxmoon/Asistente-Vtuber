{
  "name": "vtuber-overlay",
  "version": "1.0.0",
  "description": "Overlay VTuber Live2D siempre encima de otras ventanas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node fix-electron.js",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.vtuber.overlay",
    "productName": "VTuber Overlay",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "models/**/*",
      "Models/**/*"
    ]
  }
}
